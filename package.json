{
  "name": "backlog-setup",
  "version": "1.0.0",
  "description": "One-command AI kanban board with semantic search for any repo.",
  "bin": {
    "backlog-setup": "setup.mjs"
  },
  "files": [
    "setup.mjs",
    "lib/",
    "skills/",
    "backlog-commit-hook.sh"
  ],
  "scripts": {
    "test": "node --test test/*.test.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Hodnebo/backlog-setup.git"
  },
  "keywords": [
    "backlog",
    "kanban",
    "mcp",
    "ai",
    "semantic-search",
    "rag",
    "tasks",
    "project-management"
  ],
  "author": "Hodnebo",
  "license": "MIT",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/Hodnebo/backlog-setup/issues"
  },
  "homepage": "https://github.com/Hodnebo/backlog-setup#readme",
  "publishConfig": {
    "provenance": true
  },
  "dependencies": {
    "mcp-local-rag": "^0.8.0"
  },
  "devDependencies": {
    "@semantic-release/npm": "^13.1.5",
    "semantic-release": "^24.0.0"
  },
  "overrides": {
    "semantic-release": {
      "@semantic-release/npm": "$@semantic-release/npm"
    }
  }
}
